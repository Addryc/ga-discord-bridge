# Copy to .env and `set -a; source .env; set +a` (or use your own env loader).
# Never commit .env or key files.

# Numeric GA4 property id — GA Admin → Property settings.
# NOT the G-XXXXXXX measurement id (that's the browser tag's id).
GA_PROPERTY_ID=

# Discord incoming webhook for the channel that should receive digests:
# Channel settings → Integrations → Webhooks → New Webhook → Copy URL.
# Required for posting; optional if you only ever run with --dry-run.
DISCORD_WEBHOOK_URL=

# IANA time zone matching the GA4 property's configured time zone
# (GA Admin → Property settings → Reporting time zone). GA aggregates days
# in that zone, so a mismatch makes "yesterday" straddle two GA days.
# Defaults to UTC when unset.
GA_PROPERTY_TIMEZONE=

# Path to a service-account key file, for running anywhere outside GCP.
# On Cloud Functions / Cloud Run / GCE, LEAVE THIS UNSET — the runtime's
# service account provides tokens via the metadata server, no key file.
GOOGLE_APPLICATION_CREDENTIALS=
